# Base environment for shared Docker Compose configuration.
# For local development, copy `.env.dev` to `.env`.
# For Docker deployment, copy `.env.prod` to `.env`.
# `COMPOSE_PROFILES` controls which service groups start when you run `docker compose up`.

# Example:
# Local infra only: `docker compose up --profile infra`
# Docker app stack: use `.env.prod` as `.env`, then run `docker compose up`

# Default active profiles for plain `docker compose up`.
COMPOSE_PROFILES=

###############
### LiveKit ###
###############
# Public LiveKit URL used by clients outside Docker.
LIVEKIT_URL=wss://your-livekit-host
# API key used by backend token generation and LiveKit server auth.
LIVEKIT_API_KEY=replace-with-livekit-api-key
# API secret paired with LIVEKIT_API_KEY.
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
# LiveKit server URL reachable by a locally running backend process.
LIVEKIT_SERVER_URL=http://localhost:7880
# LiveKit server URL reachable by containers inside Docker Compose.
LIVEKIT_DOCKER_URL=http://livekit:7880
# Published LiveKit HTTP port on the host machine.
LIVEKIT_PORT=7880
# Published LiveKit signal/TCP port on the host machine.
LIVEKIT_SIGNAL_PORT=7881
# Published LiveKit UDP RTC port on the host machine.
LIVEKIT_RTC_UDP_PORT=7882
# Frontend browser URL for connecting to LiveKit.
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
# Default room name used by the demo frontend.
NEXT_PUBLIC_LIVEKIT_ROOM=my-room

###############
### Backend ###
###############
# Backend HTTP port exposed by Docker Compose.
BACKEND_PORT=3000
# Public backend host, useful for docs and external integrations.
BACKEND_HOST=http://localhost
# Kafka bootstrap servers used by a locally running Nest backend.
KAFKA_BROKERS=localhost:9092
# Kafka consumer group used by the Nest backend.
KAFKA_CONSUMER_GROUP=nestjs-producer-consumer
# Node runtime options for frontend and backend containers.
NODE_OPTIONS=--max_old_space_size=4096

################
### Frontend ###
################
# Frontend HTTP port exposed by Docker Compose.
FRONTEND_PORT=3001
# Public frontend host, useful for docs and external integrations.
FRONTEND_HOST=http://localhost

###############
### PorgreSQL ###
###############
# MongoDB host port exposed by Docker Compose.
POSTGRES_PORT=5432
# PorgreSQL admin username.
POSTGRES_USER=change-me
# PorgreSQL admin password.
POSTGRES_PASSWORD=change-me
# Default PorgreSQL database name for the app.
POSTGRES_DB=vkedu
# PorgreSQL connection string for a locally running backend.
DATABASE_URL=postgresql://admin:change-me@postgres:5432/vkedu

#############
### Redis ###
#############
# Redis container port used internally by Compose services.
REDIS_CONTAINER_PORT=6379
# Host port for the LiveKit Redis instance.
LIVEKIT_REDIS_PORT=6380
# Redis host used by local ML workers.
REDIS_HOST=localhost
# Redis port used by local ML workers.
REDIS_PORT=6380

#############
### Kafka ###
#############
# Host port exposed for Kafka access from the local machine.
KAFKA_EXTERNAL_PORT=9092
# Internal broker listener port used by containers.
KAFKA_INTERNAL_PORT=29092
# Internal controller listener port used by Kafka KRaft.
KAFKA_CONTROLLER_PORT=29093
# Kafka broker identifier.
KAFKA_BROKER_ID=1
# Kafka node identifier for KRaft mode.
KAFKA_NODE_ID=1
# Listener security map for the single-node dev broker.
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT,CONTROLLER:PLAINTEXT
# Advertised listeners visible inside Docker and from the local host.
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://broker:29092,PLAINTEXT_HOST://localhost:9092
# Listener bindings for broker, controller, and host access.
KAFKA_LISTENERS=PLAINTEXT://broker:29092,CONTROLLER://broker:29093,PLAINTEXT_HOST://0.0.0.0:9092
# Combined broker/controller roles for single-node development.
KAFKA_PROCESS_ROLES=broker,controller
# Controller quorum voters for KRaft mode.
KAFKA_CONTROLLER_QUORUM_VOTERS=1@broker:29093
# Broker listener name used for inter-broker communication.
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT
# Controller listener name used in KRaft mode.
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
# Kafka log directory inside the container.
KAFKA_LOG_DIRS=/tmp/kraft-combined-logs
# Single-node topic replication factor.
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
# Consumer rebalance delay in milliseconds.
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0
# Minimum ISR for transaction state topic.
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
# Replication factor for transaction state topic.
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
# Cluster ID for the single-node Kafka instance.
KAFKA_CLUSTER_ID=replace-with-stable-kafka-cluster-id
# Kafka bootstrap server string used by local ML workers.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

#################
### ML Workers ###
#################
# Consumer group for ML input worker.
MLIN_KAFKA_GROUP_ID=mlin_group
# Topics consumed by ML input worker.
MLIN_KAFKA_TOPICS=speechEvent,boardEvent
# Consumer group for ML output worker.
MLOUT_KAFKA_GROUP_ID=mlout_group
# Topics consumed by ML output worker.
MLOUT_KAFKA_TOPICS=chatEvent,summaryEvent

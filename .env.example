# This is default .env file for development.
# Copy this file to .env and update values as needed.
# IN PRODUCTION: ensure to change values after copying
#
# Run modes:
# - Local without Docker: keep localhost defaults and run `yarn dev`.
# - Local in Docker through nginx: set Docker host overrides in `.env.production`,
#   set `NEXT_PUBLIC_LIVEKIT_URL=ws://localhost/rtc`,
#   `NEXT_PUBLIC_BACKEND_URL=http://localhost/api`,
#   `NGINX_SERVER_NAME=localhost`, and `NGINX_REDIRECT_TO_HTTPS=false`.
# - Domain in Docker through nginx: set Docker host overrides in `.env.production`,
#   set `NEXT_PUBLIC_LIVEKIT_URL=wss://your-domain.example/rtc`,
#   `NEXT_PUBLIC_BACKEND_URL=https://your-domain.example/api`,
#   `NGINX_SERVER_NAME=your-domain.example www.your-domain.example`,
#   `NGINX_REDIRECT_TO_HTTPS=true`, and point nginx cert vars to mounted certs.

# Name variables like:
# SERVICE_VAR=value
# SERVICE_VAR_LIST=value1,value2,value3

###############
### General ###
###############
NODE_ENV=development
                        # OR production

###############
### Backend ###
###############
BACKEND_DATABASE_HOST=localhost
                        # OR postgres (if accessed from within Docker)
BACKEND_KAFKA_HOST=localhost  
                        # OR broker (if accessed from within Docker)
BACKEND_LIVEKIT_HOST=http://localhost:7880
                        # Can't work with localhost

BACKEND_PORT=3000

BACKEND_SUPERUSER_PASSWORD=changeme

BACKEND_KAFKA_CLIENT_ID=backend_kafka_client
BACKEND_KAFKA_CONSUMER_GROUP_ID=backend_consumer_group

BACKEND_JWT_SECRET=hmi7q2KtAp103B6FvEeZeLnmG9Q5eOkl0P2t2EYI6ND
BACKEND_JWT_EXPIRES_IN=15m
BACKEND_JWT_REFRESH_EXPIRES_IN=7d

######################
### Object Storage ###
######################
S3_ENDPOINT=http://localhost:9000
                        # OR http://rustfs:9000 if backend runs inside Docker
S3_REGION=us-east-1
S3_BUCKET=broadboard-context
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin
S3_FORCE_PATH_STYLE=true
S3_DOWNLOAD_TTL_SECONDS=900
S3_PORT=9000
S3_CONSOLE_PORT=9001

################
### Database ###
################
POSTGRES_PORT=5432
POSTGRES_DB=BB_db
POSTGRES_USER=BB_user
POSTGRES_PASSWORD=BB_password
# Ensure to override DATABASE_URL in production with compose
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${BACKEND_DATABASE_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

#############
### Redis ###
#############
REDIS_HOST=localhost
                        # OR redis (if accessed from within Docker)
REDIS_PORT=6379

#############
### Kafka ###
#############
KAFKA_PORT=29092      
                        # OR 9092 (if accessed within Docker)

###############
### LiveKit ###
###############
LIVEKIT_PORT=7880
LIVEKIT_RTC_USE_EXTERNAL_IP=false
LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_RTC_UDP_PORT_START=8000
LIVEKIT_RTC_UDP_PORT_END=8010
LIVEKIT_TURN_ENABLED=false
LIVEKIT_TURN_UDP_PORT=3478
LIVEKIT_TURN_TLS_PORT=5349
LIVEKIT_TURN_DOMAIN=localhost
LIVEKIT_TURN_CERT_FILE=/etc/livekit/certs/local.crt
LIVEKIT_TURN_KEY_FILE=/etc/livekit/certs/local.key

LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdev12
LIVEKIT_API_KEY=devkey

#####################
### LiveKit Agent ###
#####################
LIVEKIT_AGENT_LIVEKIT_URL=ws://localhost:7880
                        # OR ws://livekit:7880 (if accessed from within Docker)
LIVEKIT_AGENT_NAME=default-agent
LIVEKIT_AGENT_LOG_LEVEL=INFO
LIVEKIT_AGENT_SILENCE_DURATION=0.5

KAFKA_BOOTSTRAP_SERVERS=localhost:29092
                        # OR broker:9092 (if accessed from within Docker)
KAFKA_TRANSCRIPT_TOPIC=calls.transcript
KAFKA_CHAT_TOPIC=calls.chat

WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru

################
### FRONTEND ###
################
FRONTEND_PORT=3001

NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
                        # OR wss://broadboard.ru on production domain
                        # OR ws://localhost if running in Docker with nginx
NEXT_PUBLIC_LIVEKIT_ROOM=my-room
NEXT_PUBLIC_LIVEKIT_AGENT_NAME=default-agent
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
                        # OR https://broadboard.ru/api when browser requests should go through nginx
FRONTEND_INTERNAL_BACKEND_URL=http://localhost:3000
                        # OR https://broadboard.ru/api when running on domain
                        # OR http://backend:3000 if running in Docker with nginx
NODE_OPTIONS=--max_old_space_size=4096

#############
### Nginx ###
#############
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_SERVER_NAME=localhost
                        # OR broadboard.ru www.broadboard.ru on production server
NGINX_REDIRECT_TO_HTTPS=false
                        # Use true on a domain with valid certificates
# Redirect for docker containers
NGINX_FRONTEND_UPSTREAM=frontend:3001
NGINX_BACKEND_UPSTREAM=backend:3000
NGINX_LIVEKIT_UPSTREAM=livekit:7880
# Dummy self-signed certs for local development;
NGINX_SSL_CERTIFICATE=/etc/nginx/certs/local.crt
                        # OR /etc/nginx/certs/certificate.crt on production server
NGINX_SSL_CERTIFICATE_KEY=/etc/nginx/certs/local.key
                        # OR /etc/nginx/certs/certificate.key on production server


#############
### ML IN ###
#############
MLIN_KAFKA_GROUP_ID=mlin_group
MLIN_KAFKA_TOPICS=speechEvent,boardEvent

##############
### ML OUT ###
##############
MLOUT_KAFKA_GROUP_ID=mlout_group
MLOUT_KAFKA_TOPICS=chatEvent,summaryEvent
